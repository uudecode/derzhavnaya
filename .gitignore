# --- Специфичные файлы GoLand (JetBrains) ---
.idea/
*.iml
*.iws
*.ipr
# Если вы используете встроенный HTTP-клиент
.idea/httpRequests/

# --- Бинарные файлы и артефакты сборки ---
bin/
out/
dist/
# Исполняемые файлы (обычно без расширения в Unix или .exe в Windows)
*.exe
*.exe~
*.dll
*.so
*.dylib
# Скомпилированные тесты
*.test

# --- Зависимости ---
# Обычно папку vendor не игнорируют, если вы используете `go mod vendor`,
# но если вы предпочитаете скачивать их каждый раз — раскомментируйте:
# vendor/

# --- Логи и временные файлы ---
*.log
tmp/
.temp/

# --- Переменные окружения (Секреты) ---
.env
.env.local
.env.*.local

# --- Файлы операционной системы ---
.DS_Store
Thumbs.db
main.exe